<!DOCTYPE html>{% capture language %}{% if lang %}{{ lang }}{% else %}{{ site.lang }}{% endif %}{% endcapture %}
<html xmlns="http://www.w3.org/1999/xhtml" lang="{{ language }}">
<head>
    <title>{{ company.name }}{% if title %} | {{ title }}{% endif %}</title>
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","author":{"@type":"Person","name":{{ person.name | jsonify }},"url":{{ baseUrl | jsonify }}},"headline":{{ company.name | jsonify }},"image":{"alt":{{ person.name | jsonify }},"height":534,"width":800,"url":{{ person.image | jsonify }},"@type":"imageObject"},"name":{{ company.name | jsonify }},"url":{{ baseUrl | jsonify }}}</script>
    <script type="application/ld+json">{{ company | jsonify }}</script>
    <script type="application/ld+json">{{ person | jsonify }}</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="{{ person.name }}" />
    <meta property="og:locale" content="{{ language }}" />
    <meta property="og:url" content="{{ page.url | absolute_url }}" />
    <meta property="og:site_name" content="{{ company.name }}" />
    <meta property="og:image" content="{{ '/assets/img/landscape-800x534.jpg' | absolute_url }}" />
    <meta property="og:image:height" content="534" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:alt" content="{{ person.name }}" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content="{{ '/assets/img/landscape-800x534.jpg' | absolute_url }}" />
    <meta name="twitter:image:alt" content="{{ person.name }}" />
    <meta property="twitter:title" content="{% if title %}{{ title }}{% else %}{{ company.name }}{% endif %}" />
    <link rel="canonical" href="{{ page.url | absolute_url }}" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/handiman/henrikbecker.net.chat.ui@0.0.23/dist/collection/cv-chat.css" />
    <link rel="stylesheet" href="/assets/main.css" />
    {% for format in formats %}<link rel="alternate" type="{{ format.mime_type }}" title="My CV in {{ format.name }} format" href="{{ format.url }}" />
    {% endfor %}
    <script type="module">
        import { defineCustomElements } from 'https://cdn.jsdelivr.net/gh/handiman/henrikbecker.net.chat.ui@0.0.23/dist/esm/loader.js';
        defineCustomElements();
    </script>        
</head>
<body>
    {% include 'header' %}
    <main id="content">
        {{ content }}
    </main>
    {% include 'footer' %}
  <button class="theme-toggle" title="Toggle dark mode">.</button>
  <script src="/assets/main.js"></script>
</body>
</html>         