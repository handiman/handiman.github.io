---
layout: page
---
<div>
    <article>
        <header>
            <h1>{{ name }}</h1>
            <p>
                {% if roles %}<span>{% for role in roles %}{{ role }}{% unless forloop.last %}, {% endunless %}{% endfor %}</span>{% endif %}
                <time>
                    <span>{{ start_date | date: '%Y-%m'}}</span>
                    <span>{{ end_date | date: '%Y-%m' }}</span>
                </time>
            </p>
        </header>
        {{ content }}
    </article>
</div>