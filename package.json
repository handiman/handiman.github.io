{
  "license": "MIT",
  "author": "Henrik Becker",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf _site",
    "typst": "typst compile --font-path _site/assets/fonts _site/assets/henrik-becker.typ _site/assets/henrik-becker.pdf --font-path fonts",
    "build": "npm run clean && npx @11ty/eleventy && npm run typst",
    "serve": "npm run clean && npx @11ty/eleventy --serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "markdown-it": "^14.2.0",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "yaml": "^2.9.0"
  }
}
